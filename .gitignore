!data/raw/.gitkeep

# Python
__pycache__/
*.pyc
.venv/
venv/

# dbt
dbt/target/
dbt/dbt_packages/
dbt/logs/

# Great Expectations
great_expectations/uncommitted/

# OS / editor
.DS_Store
.vscode/
.idea/
