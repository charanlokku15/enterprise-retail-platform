# ============================================================
# Enterprise Retail Data Platform — Phase 1 environment config
# ============================================================
# This file is committed as .env.example in real repos.
# For local dev it's fine to keep real (non-secret) local creds here.

# ---- Airflow metadata DB (internal, not the OLTP source) ----
AIRFLOW_PG_USER=airflow
AIRFLOW_PG_PASSWORD=CHANGE_ME
AIRFLOW_PG_DB=airflow

# ---- OLTP source DB (simulates the retailer's application database) ----
OLTP_PG_USER=retail_app
OLTP_PG_PASSWORD=CHANGE_ME
OLTP_PG_DB=retail_oltp
OLTP_PG_PORT=5433

# ---- Airflow core ----
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__API__AUTH_BACKENDS=airflow.api.auth.backend.basic_auth
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=CHANGE_ME
AIRFLOW_ADMIN_FIRSTNAME=Admin
AIRFLOW_ADMIN_LASTNAME=User
AIRFLOW_ADMIN_EMAIL=admin@example.com

# Extra python packages installed into the Airflow image at startup.
# Fine for local dev; for anything long-lived, bake these into a custom
# Dockerfile instead (faster startup, reproducible builds).
_PIP_ADDITIONAL_REQUIREMENTS=duckdb==1.0.0 dbt-duckdb==1.8.1 great-expectations==0.18.19 minio==7.2.7 faker==25.8.0 psycopg2-binary==2.9.9 pandas==2.2.2 pyarrow==16.1.0

# ---- MinIO (S3-compatible object storage) ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=http://minio:9000

# ---- DuckDB ----
# DuckDB has no server/container — it's an embedded file-based warehouse.
# This is just the path every service mounts to reach the same .duckdb file.
DUCKDB_PATH=/warehouse/retail.duckdb
